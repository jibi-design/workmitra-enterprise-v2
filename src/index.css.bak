/* src/index.css */
:root {
  /* Brand */
  --wm-brand-600: #1d4ed8; /* Primary */
  --wm-brand-700: #1e40af; /* pressed/hover */

  /* Employee mood (friendly light) */
  --wm-emp-bg: #f8fafc;
  --wm-emp-card: #ffffff;
  --wm-emp-text: #0f172a;
  --wm-emp-muted: #475569;
  --wm-emp-border: rgba(15, 23, 42, 0.10);

  /* Employer mood (neutral premium light) - FINAL */
  --wm-er-bg: #f7f8fa;          /* app background */
  --wm-er-card: #ffffff;        /* card surface */
  --wm-er-border: #e6e9ef;      /* 1px border */
  --wm-er-divider: #eef1f5;     /* divider */
  --wm-er-text: #111827;        /* primary text */
  --wm-er-muted: #6b7280;       /* muted text */

  /* Employer domain accents (strip + icon tint only) - FINAL */
  --wm-er-accent-shift: #0f766e;     /* Shift (Teal) */
  --wm-er-accent-career: #3730a3;    /* Career (Indigo) */
  --wm-er-accent-workforce: #b45309; /* Workforce (Amber) */

  /* Subtle header tints (6–8% opacity feel) - FINAL MICRO-POLISH */
  --wm-er-shift-wash: rgba(15, 118, 110, 0.07);
  --wm-er-career-wash: rgba(55, 48, 163, 0.07);
  --wm-er-workforce-wash: rgba(180, 83, 9, 0.07);

  /* Feedback colors (minimal) */
  --wm-success: #16a34a;
  --wm-warning: #d97706;
  --wm-error: #dc2626;

  /* Admin mood (authority control panel) */
  --wm-ad-bg: #071024;
  --wm-ad-card: #ffffff;
  --wm-ad-text: #eaf0ff;
  --wm-ad-muted: rgba(234, 240, 255, 0.70);
  --wm-ad-border: rgba(255, 255, 255, 0.14);

  /* Radius & spacing */
  --wm-radius-14: 14px;
  --wm-radius-12: 12px;
  --wm-radius-10: 10px;

  --wm-space-8: 8px;
  --wm-space-12: 12px;
  --wm-space-16: 16px;
  --wm-space-20: 20px;

  /* Shadow: subtle only */
  --wm-shadow-soft: 0 6px 16px rgba(17, 24, 39, 0.06);

  font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  line-height: 1.5;
  font-weight: 400;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

* { box-sizing: border-box; }

html, body { height: 100%; }
body {
  margin: 0;
  background: var(--wm-emp-bg);
  color: var(--wm-emp-text);
}

a { color: inherit; text-decoration: none; }
button, input { font: inherit; }
button { -webkit-tap-highlight-color: transparent; }

.wm-app { min-height: 100vh; }

.wm-container {
  width: 100%;
  max-width: 520px;
  margin: 0 auto;
  padding: var(--wm-space-16);
}

/* Top bar (base) */
.wm-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--wm-space-12);
  padding: var(--wm-space-12) var(--wm-space-16);
  border-bottom: 1px solid var(--wm-emp-border);
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 5;
}
.wm-title { display: flex; flex-direction: column; gap: 2px; }
.wm-title h1 { margin: 0; font-size: 16px; line-height: 1.2; letter-spacing: 0.2px; }
.wm-title p { margin: 0; font-size: 12px; color: var(--wm-emp-muted); }

.wm-iconbtn {
  width: 40px;
  height: 40px;
  border-radius: var(--wm-radius-14);
  border: 1px solid var(--wm-emp-border);
  background: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

/* Primary button (single style across app) */
.wm-primarybtn {
  border: 0;
  border-radius: var(--wm-radius-14);
  padding: 10px 12px;
  font-weight: 800;
  cursor: pointer;
  background: var(--wm-brand-600);
  color: #fff;
}
.wm-primarybtn:hover { background: var(--wm-brand-700); }
.wm-primarybtn:active { transform: translateY(1px); }

/* -------------------------------- */
/* Employee styles (kept as-is) */
/* -------------------------------- */
.wm-cards {
  display: grid;
  gap: var(--wm-space-12);
  margin-top: var(--wm-space-16);
}
.wm-card {
  border: 1px solid var(--wm-emp-border);
  background: var(--wm-emp-card);
  border-radius: 18px;
  padding: var(--wm-space-16);
  box-shadow: var(--wm-shadow-soft);
  display: flex;
  justify-content: space-between;
  gap: var(--wm-space-16);
  cursor: pointer;
  position: relative;
  overflow: hidden;
}
.wm-card .left { display: flex; flex-direction: column; gap: 6px; }
.wm-card .label { font-size: 15px; font-weight: 1000; letter-spacing: 0.1px; }
.wm-card .desc { font-size: 12px; color: var(--wm-emp-muted); }

.wm-badge {
  min-width: 30px;
  height: 30px;
  border-radius: 999px;
  padding: 0 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 1000;
  background: rgba(30, 78, 216, 0.10);
  color: var(--wm-brand-700);
  border: 1px solid rgba(30, 78, 216, 0.22);
}

/* Stats (employee base) */
.wm-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--wm-space-12);
  margin-top: var(--wm-space-16);
}
.wm-stat {
  border: 1px solid var(--wm-emp-border);
  background: var(--wm-emp-card);
  border-radius: var(--wm-radius-12);
  padding: var(--wm-space-12);
}
.wm-stat .k { font-size: 11px; color: var(--wm-emp-muted); }
.wm-stat .v { margin-top: 6px; font-size: 16px; font-weight: 1000; }

.wm-footer {
  margin-top: var(--wm-space-20);
  display: flex;
  justify-content: space-between;
  gap: var(--wm-space-12);
  color: var(--wm-emp-muted);
  font-size: 12px;
}
.wm-footer a { text-decoration: underline; }

/* Shared icon chip (used by employee cards) */
.wm-iconChip {
  width: 38px;
  height: 38px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--wm-emp-border);
  background: rgba(255, 255, 255, 0.75);
  font-size: 16px;
  flex: 0 0 auto;
}

/* -------------------------------- */
/* Employer neutral premium (FINAL) */
/* -------------------------------- */
.wm-er-bg { background: var(--wm-er-bg); color: var(--wm-er-text); }
.wm-er-topbar {
  border-bottom: 1px solid var(--wm-er-border);
  background: rgba(255, 255, 255, 0.92);
}
.wm-er-topbar .wm-title h1 { font-size: 18px; font-weight: 700; }
.wm-er-topbar .wm-title p { color: var(--wm-er-muted); font-size: 12px; }
.wm-er-topbar .wm-iconbtn {
  border: 1px solid var(--wm-er-border);
  border-radius: var(--wm-radius-14);
  background: #fff;
}

/* Employer tiles (top stats) */
.wm-er-tiles {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--wm-space-12);
  margin-top: 0;
}
.wm-er-tile {
  border: 1px solid var(--wm-er-border);
  background: var(--wm-er-card);
  border-radius: var(--wm-radius-14);
  padding: 14px;
}
.wm-er-tileTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.wm-er-tileLabel { font-size: 12px; color: var(--wm-er-muted); }
.wm-er-tileValue { margin-top: 6px; font-size: 22px; font-weight: 1000; color: var(--wm-er-text); }
.wm-er-tileIcon {
  width: 32px;
  height: 32px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--wm-er-divider);
  background: #fff;
  color: var(--wm-er-muted);
  font-size: 16px;
}

/* Employer domain cards */
.wm-er-card {
  border: 1px solid var(--wm-er-border);
  background: var(--wm-er-card);
  border-radius: var(--wm-radius-14);
  padding: 16px;
  position: relative;
  overflow: hidden; /* ensures strip clips perfectly */
}
.wm-er-card + .wm-er-card { margin-top: var(--wm-space-12); }

/* Accent strip: perfect clipping + radius match (FINAL) */
.wm-er-accentCard::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: var(--wm-er-accent, var(--wm-brand-600));
  border-top-left-radius: var(--wm-radius-14);
  border-bottom-left-radius: var(--wm-radius-14);
}

/* Header tint (ONLY title + subtitle area) */
.wm-er-headTint {
  margin-left: -16px;
  margin-right: -16px;
  margin-top: -16px;
  padding: 12px 16px 12px 16px;
  border-bottom: 1px solid var(--wm-er-divider);
  background: var(--wm-er-wash, transparent);
}

.wm-er-cardHead {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--wm-space-12);
}

.wm-er-titleRow {
  display: flex;
  align-items: center;
  gap: 10px;
}

.wm-er-domainIcon {
  width: 36px;
  height: 36px;
  border-radius: var(--wm-radius-14);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--wm-er-divider);
  background: rgba(255, 255, 255, 0.85);
  font-size: 16px;
  color: var(--wm-er-accent, var(--wm-brand-600));
}

.wm-er-cardTitle {
  margin: 0;
  font-size: 16px;
  font-weight: 700;
  color: var(--wm-er-text);
  line-height: 1.2;
}

/* Subtitle: FINAL RULE = 1 line only (ellipsis) */
.wm-er-cardSub {
  margin-top: 6px;
  font-size: 13px;
  color: var(--wm-er-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 320px;
}

/* Chips (neutral only) */
.wm-er-chips {
  margin-top: 12px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.wm-er-chip {
  height: 28px;
  border-radius: 999px;
  padding: 0 12px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #f4f6f8;
  border: 1px solid #e5e7eb;
  font-size: 12px;
  color: var(--wm-er-text);
}
.wm-er-chip .n {
  font-weight: 900;
  color: var(--wm-er-text);
}

/* Employer insights card */
.wm-er-insights {
  margin-top: var(--wm-space-12);
  border: 1px solid var(--wm-er-border);
  background: var(--wm-er-card);
  border-radius: var(--wm-radius-14);
  padding: 16px;
}
.wm-er-insightsHead {
  display: flex;
  align-items: baseline; /* pixel alignment */
  justify-content: space-between;
  gap: 12px;
}
.wm-er-insightsTitle {
  margin: 0;
  font-size: 14px;
  font-weight: 800;
  color: var(--wm-er-text);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  line-height: 1;
}
.wm-er-linkBtn {
  border: 0;
  background: transparent;
  color: var(--wm-brand-600);
  font-weight: 800;
  cursor: pointer;
  padding: 0;
  line-height: 1;
}
.wm-er-linkBtn:hover { color: var(--wm-brand-700); }

.wm-er-kpis {
  margin-top: 10px;
  display: grid;
  gap: 10px;
}
.wm-er-kpiRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 10px;
  border-top: 1px solid var(--wm-er-divider);
}
.wm-er-kpiRow:first-child { border-top: 0; padding-top: 0; }
.wm-er-kpiLabel { font-size: 12px; color: var(--wm-er-muted); }
.wm-er-kpiValue { font-size: 14px; font-weight: 900; color: var(--wm-er-text); }

/* Employer variant mapping -> sets accent + wash */
.wm-er-vShift { --wm-er-accent: var(--wm-er-accent-shift); --wm-er-wash: var(--wm-er-shift-wash); }
.wm-er-vCareer { --wm-er-accent: var(--wm-er-accent-career); --wm-er-wash: var(--wm-er-career-wash); }
.wm-er-vWorkforce { --wm-er-accent: var(--wm-er-accent-workforce); --wm-er-wash: var(--wm-er-workforce-wash); }

/* -------------------------------- */
/* Admin (unchanged) */
/* -------------------------------- */
.wm-admin-bg { background: var(--wm-ad-bg); color: var(--wm-ad-text); }
.wm-admin-topbar {
  background: rgba(7, 16, 36, 0.92);
  border-bottom: 1px solid var(--wm-ad-border);
}
.wm-admin-topbar .wm-title p { color: var(--wm-ad-muted); }
.wm-admin-topbar .wm-iconbtn {
  border: 1px solid var(--wm-ad-border);
  background: rgba(255, 255, 255, 0.06);
  color: var(--wm-ad-text);
}
.wm-admin-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--wm-space-12);
  margin-top: var(--wm-space-16);
}
.wm-admin-card {
  background: var(--wm-ad-card);
  color: #0b1220;
  border-radius: var(--wm-radius-12);
  padding: var(--wm-space-16);
}
.wm-admin-card .k { font-size: 11px; color: #475569; }
.wm-admin-card .v { margin-top: 6px; font-size: 18px; font-weight: 1000; }